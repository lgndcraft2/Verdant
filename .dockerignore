# Keep the build context small and secrets out of the image.
.git
.gitignore

# Secrets / local env
.env
.env.local
*.env

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
sdk/dist/
sdk/build/

# Virtualenvs
.venv/
.venv-testpypi/
venv/
env/

# Node / dashboard (not part of the API image)
dashboard/node_modules/
dashboard/.next/
dashboard/.dev.*.log

# Editor / OS
.vscode/
.idea/
.DS_Store

# Docs & tests aren't needed at runtime
tests/
docs/

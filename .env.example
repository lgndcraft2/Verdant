# API / SDK
VERDANT_API_KEY=
# Point the SDK at a hosted VERDANT API to run the pipeline server-side (SaaS mode).
# Leave blank to run the pipeline in-process. Issue the key from the dashboard Settings page.
VERDANT_API_URL=https://verdant-be.onrender.com
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=https://verdant-be.onrender.com

# Cache
REDIS_URL=redis://localhost:6379/0

# Webhooks
WEBHOOK_SECRET=

# Config
ENVIRONMENT=development
LOG_LEVEL=info
TRUST_SCORE_ALERT_THRESHOLD=40
CORS_ORIGINS=http://localhost:3000,https://verdant-be.onrender.com
REQUEST_TIMEOUT_SECONDS=30
WEBHOOK_TIMEOUT_SECONDS=10
